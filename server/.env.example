# SQL Server (SSMS)
DB_SERVER=localhost
DB_DATABASE=DataFlowAssurance
DB_USER=sa
DB_PASSWORD=your_password
DB_TRUST_CERTIFICATE=true

# JWT (minimum 32 caractères aléatoires en production)
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Sécurité (bcrypt : 12 recommandé en production)
BCRYPT_ROUNDS=12

# Server
PORT=3000


